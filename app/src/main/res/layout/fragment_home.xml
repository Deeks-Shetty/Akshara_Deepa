<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Purple Header for Home -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/purple_primary"
            android:padding="24dp"
            android:text="Home"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/home_content_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:animateLayoutChanges="true">

                <!-- Welcome Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/welcome_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Namaste!"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready to master your subjects?"
                            android:textSize="16sp"
                            android:textColor="#546E7A" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Overall Progress Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/progress_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    android:layout_marginBottom="24dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_gradient_home"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Syllabus Progress"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/overall_progress_bar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:progress="0"
                            app:trackColor="#33FFFFFF"
                            app:indicatorColor="@color/white"
                            app:trackThickness="10dp"
                            app:trackCornerRadius="5dp" />

                        <TextView
                            android:id="@+id/progress_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="0% of Syllabus Completed"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:alpha="0.9" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Daily Goal Tracker -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Study Goal"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#37474F"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/goal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#263238"
                    android:layout_marginBottom="24dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/goal_status_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/checkbox_off_background"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/goal_text"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Complete at least 1 topic"
                            android:textSize="17sp"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/daily_goal_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/1"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Subject Cards -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Subjects"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#37474F"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/subjects_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_subject_card" />

                <!-- Gap Area Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus Areas"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="#D32F2F"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/gap_areas_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_gap_area" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
